{
  "name": "opencode-statusline",
  "version": "0.1.0",
  "description": "OpenCode statusline and provider usage plugin with zero context pollution.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "default": "./dist/tui.tsx"
    }
  },
  "oc-plugin": [
    "server",
    "tui"
  ],
  "files": [
    "dist",
    "doc",
    "README*.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/prepare-tui-dist.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "opencode",
    "plugin",
    "statusline",
    "quota",
    "usage"
  ],
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.3",
    "@opentui/solid": "^0.2.7",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
